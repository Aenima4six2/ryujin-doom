+// Caption font matching the style of the captions baked into STBAR/STARMS
+// (AMMO, HEALTH, ARMS, ...): chunky 5-row glyphs in a light gray gradient
+// that brightens toward the baseline, with a dark shadow one pixel below
+// and to the right.
+#define ST_CAPHEIGHT	5
+#define ST_CAPMAXWIDTH	64
+
+// Body shades, top row to baseline.
+static const byte	st_capshades[ST_CAPHEIGHT] = { 96, 94, 92, 90, 88 };
+#define ST_CAPEDGE	111	// shadow right of a stroke
+#define ST_CAPSHADOW	5	// shadow below a stroke
+
+typedef struct
+{
+    char	ch;
+    char	w;
+    const char	*rows[ST_CAPHEIGHT];
+} st_capglyph_t;
+
+static const st_capglyph_t st_capfont[] =
+{
+    { 'A', 6, { ".####.", "##..##", "######", "##..##", "##..##" } },
+    { 'C', 6, { ".####.", "##....", "##....", "##....", ".####." } },
+    { 'D', 6, { "####..", "##..##", "##..##", "##..##", "####.." } },
+    { 'F', 5, { "#####", "##...", "####.", "##...", "##..." } },
+    { 'I', 4, { "####", ".##.", ".##.", ".##.", "####" } },
+    { 'L', 5, { "##...", "##...", "##...", "##...", "#####" } },
+    { 'M', 7, { "##...##", "###.###", "##.#.##", "##...##", "##...##" } },
+    { 'N', 6, { "##..##", "###.##", "##.###", "##..##", "##..##" } },
+    { 'P', 6, { "####..", "##..##", "##..##", "####..", "##...." } },
+    { 'Q', 6, { ".####.", "##..##", "##..##", "##.###", ".#####" } },
+    { 'R', 6, { "####..", "##..##", "####..", "##.##.", "##..##" } },
+    { 'U', 6, { "##..##", "##..##", "##..##", "##..##", ".####." } },
+    { '\0', 0, { NULL, NULL, NULL, NULL, NULL } }
+};
+
+static const st_capglyph_t *ST_capGlyph(char ch)
+{
+    const st_capglyph_t *g;
+
+    for (g = st_capfont; g->ch; g++)
+	if (g->ch == toupper((unsigned char)ch))
+	    return g;
+    return NULL;
+}
+
+// Wipe a baked caption band by shifting the leather texture from just
+// above down over it, so the redrawn caption sits on matching background.
+static void ST_eraseLabelBand(int x0, int x1)
+{
+    int y;
+
+    for (y = ST_LABELBANDTOP; y <= ST_LABELBANDBOTTOM; y++)
+	memcpy(st_backing_screen + y * ST_WIDTH + x0,
+	       st_backing_screen + (y - ST_LABELBANDUP) * ST_WIDTH + x0,
+	       x1 - x0 + 1);
+}
+
+// Clone a vertical strip of leather over another region of the backing
+// screen, full height so the bar's top highlight and bottom trim survive.
+// Used to hide the baked ammo counter cluster and the old panel dividers.
+static void ST_cloneLeather(int dst_x, int src_x, int w)
+{
+    int y;
+
+    for (y = 0; y < ST_HEIGHT; y++)
+	memcpy(st_backing_screen + y * ST_WIDTH + dst_x,
+	       st_backing_screen + y * ST_WIDTH + src_x, w);
+}
+
+// Hide obsolete panel furniture under cloned leather.  The original key-box
+// bevel supplies both restored telemetry splitters after the large clone.
+static void ST_coverAmmoCluster(void)
+{
+    ST_cloneLeather(ST_BEVEL0_DST, ST_BEVEL0_SRC, ST_BEVELWIDTH);
+    ST_cloneLeather(ST_BEVEL1_DST, ST_BEVEL1_SRC, ST_BEVELWIDTH);
+    ST_cloneLeather(ST_CLONEDSTX, ST_CLONESRCX, ST_CLONEWIDTH);
+    ST_cloneLeather(ST_PUMP_LIQ_SPLITTERX, ST_BEVEL2_DST, ST_BEVELWIDTH);
+    ST_cloneLeather(ST_FAN_CPU_SPLITTERX, ST_BEVEL2_DST, ST_BEVELWIDTH);
+    ST_cloneLeather(ST_BEVEL2_DST, ST_BEVEL2_SRC, ST_BEVELWIDTH);
+}
+
+// Draw a caption centered on center_x into st_backing_screen, in the
+// baked-caption style.  y is the top body row; shadows extend one row
+// below and one column right of the text.
+static void ST_drawLabel(int center_x, int y, const char *label)
+{
+    // Composed label; one extra shadow row and column.
+    byte	body[ST_CAPHEIGHT + 1][ST_CAPMAXWIDTH + 1];
+    int		width = 0;
+    int		row, col;
+    const char	*p;
+    byte	*out;
+
+    memset(body, 0, sizeof(body));
+
+    for (p = label; *p; p++)
+    {
+	const st_capglyph_t *g = ST_capGlyph(*p);
+
+	if (!g)
+	{
+	    width += 3;
+	    continue;
+	}
+	if (width + g->w > ST_CAPMAXWIDTH)
+	    break;
+	for (row = 0; row < ST_CAPHEIGHT; row++)
+	    for (col = 0; col < g->w; col++)
+		if (g->rows[row][col] != '.')
+		    body[row][width + col] = 1;
+	width += g->w + 1;
+    }
+    if (width)
+	width--;	// no gap after the last glyph
+
+    out = st_backing_screen + y * ST_WIDTH + center_x - width / 2;
+    for (row = 0; row <= ST_CAPHEIGHT; row++)
+	for (col = 0; col <= width; col++)
+	{
+	    if (body[row][col])
+		out[row * ST_WIDTH + col] = st_capshades[row];
+	    else if (col && body[row][col - 1])
+		out[row * ST_WIDTH + col] = ST_CAPEDGE;
+	    else if (row && body[row - 1][col])
+		out[row * ST_WIDTH + col] = ST_CAPSHADOW;
+	    else if (row && col && body[row - 1][col - 1])
+		out[row * ST_WIDTH + col] = ST_CAPSHADOW;
+	}
+}
+
+// Draw one of the big telemetry numbers centered on center_x, clearing the
+// whole field first so shrinking values leave no stale digits.  Values are
+// non-negative and clamped to maxdigits.
+static void ST_drawRyujinNum(int center_x, int value, int maxdigits)
+{
+    int		w = SHORT(tallnum[0]->width);
+    int		h = SHORT(tallnum[0]->height);
+    int		field = maxdigits * w;
+    int		x0 = center_x - field / 2;
+    int		ndigits = 1;
+    int		tmp, total, x, i;
+
+    for (tmp = 10, i = 1; i < maxdigits; tmp *= 10, i++)
+	if (value >= tmp)
+	    ndigits = i + 1;
+    if (value >= tmp)
+	value = tmp - 1;
+
+    V_CopyRect(x0, ST_STATSY - ST_Y, st_backing_screen, field, h,
+	       x0, ST_STATSY);
+
+    if (value < 0)
+	return;
+
+    total = ndigits * w;
+    x = center_x + total / 2;
+    while (ndigits--)
+    {
+	x -= w;
+	V_DrawPatch(x, ST_STATSY, tallnum[value % 10]);
+	value /= 10;
+    }
+}
