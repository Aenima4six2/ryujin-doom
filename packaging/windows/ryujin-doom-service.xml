<service>
  <id>ryujin-doom</id>
  <name>Ryujin Doom</name>
  <description>DOOM and live cooler/CPU telemetry on the ASUS ROG Ryujin III Extreme LCD.</description>
  <executable>%BASE%\ryujin-doom.exe</executable>
  <arguments>-iwad "%ProgramData%\ryujin-doom\IWAD.WAD"</arguments>
  <workingdirectory>%BASE%</workingdirectory>
  <prestart>
    <executable>powershell.exe</executable>
    <arguments>-NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "%BASE%\armoury-crate-stop.ps1" -StatePath "%ProgramData%\ryujin-doom\armoury-crate-state.json" -LogPath "%BASE%\logs\armoury-crate.log"</arguments>
    <stdoutPath>NUL</stdoutPath>
    <stderrPath>NUL</stderrPath>
  </prestart>
  <poststart>
    <executable>powershell.exe</executable>
    <arguments>-NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "%BASE%\armoury-crate-stop.ps1" -StatePath "%ProgramData%\ryujin-doom\armoury-crate-state.json" -LogPath "%BASE%\logs\armoury-crate.log" -Refresh -DelaySeconds 5</arguments>
    <stdoutPath>NUL</stdoutPath>
    <stderrPath>NUL</stderrPath>
  </poststart>
  <poststop>
    <executable>powershell.exe</executable>
    <arguments>-NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "%BASE%\armoury-crate-restore.ps1" -StatePath "%ProgramData%\ryujin-doom\armoury-crate-state.json" -LogPath "%BASE%\logs\armoury-crate.log"</arguments>
    <stdoutPath>NUL</stdoutPath>
    <stderrPath>NUL</stderrPath>
  </poststop>
  <startmode>Manual</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  <stoptimeout>10sec</stoptimeout>
  <stopparentprocessfirst>true</stopparentprocessfirst>
  <onfailure action="restart" delay="5 sec" />
  <resetfailure>1 hour</resetfailure>
  <serviceaccount>
    <user>LocalSystem</user>
  </serviceaccount>
  <logpath>%BASE%\logs</logpath>
  <log mode="roll" />
</service>
